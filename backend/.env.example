# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://fsadmin:FS_S3cur3_P4ss!@localhost:5432/franciscostore"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=sua_chave_jwt_super_secreta_aqui_minimo_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=sua_chave_refresh_super_secreta_aqui_minimo_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Bcrypt ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=100

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM=noreply@franciscostore.com
STORE_NAME=Francisco Store

# ── Cloudinary (Upload de imagens) ───────────────────────────
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ── Stripe (Pagamentos internacionais) ───────────────────────
STRIPE_SECRET_KEY=sk_test_sua_chave_aqui
STRIPE_WEBHOOK_SECRET=whsec_sua_chave_aqui

# ── Mercado Pago (PIX / Boleto) ───────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-sua_token_aqui

# ── App URL (para webhooks) ───────────────────────────────────
APP_URL=http://localhost:4000

# ── Redis (opcional) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
